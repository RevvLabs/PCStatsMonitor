<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PCStatsMonitor.App.ViewModels"
        xmlns:views="clr-namespace:PCStatsMonitor.App.Views"
        x:Class="PCStatsMonitor.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="PC Stats Monitor"
        Width="700" Height="460"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F10"
        FontFamily="Inter, Segoe UI"
        CanResize="False"
        RenderOptions.EdgeMode="Antialias"
        UseLayoutRounding="True">

  <Panel>

    <DockPanel>

      <!-- Header bar — flat, hairline divider only -->
      <Border DockPanel.Dock="Top"
              Height="50"
              BorderBrush="#1F2023"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto,Auto" Margin="22,0,16,0">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                      VerticalAlignment="Center">
            <TextBlock Text="PC STATS"
                       FontSize="12" FontWeight="Bold"
                       LetterSpacing="2.5"
                       Foreground="#ECEDEF"
                       VerticalAlignment="Center"/>
            <TextBlock Text="MONITOR"
                       FontSize="12" FontWeight="Normal"
                       LetterSpacing="2.5"
                       Foreground="#6E7176"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Live indicator -->
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Spacing="7">
            <Ellipse Name="LiveDot" Width="6" Height="6" Fill="#2ECC71"/>
            <TextBlock Text="LIVE"
                       FontSize="9" FontWeight="SemiBold"
                       LetterSpacing="1.5"
                       Foreground="#6E7176"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Settings gear -->
          <Button Grid.Column="2"
                  Name="SettingsButton"
                  Click="OnSettingsClick"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="8,4"
                  Margin="14,0,0,0"
                  CornerRadius="6"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Settings">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#1C1D20"/>
              </Style>
            </Button.Styles>
            <TextBlock Text="⚙" FontSize="15" Foreground="#9A9DA3"/>
          </Button>

        </Grid>
      </Border>

      <!-- Update-available notification strip (hidden until a newer release is found) -->
      <Border Name="UpdateBanner"
              DockPanel.Dock="Top"
              IsVisible="False"
              Background="#14233A"
              BorderBrush="#1F2023"
              BorderThickness="0,0,0,1"
              Padding="14,5">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0" Name="UpdateBannerText"
                     Text="A new version is available"
                     FontSize="12" Foreground="#DFE0E3" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Name="UpdateBannerButton" Click="OnUpdateNowClick"
                  Background="#2A5A9E" Foreground="#ECEDEF" Padding="12,4"
                  CornerRadius="7" FontSize="12" Content="Update now"/>
          <Button Grid.Column="2" Name="UpdateBannerDismiss" Click="OnUpdateDismissClick"
                  Background="Transparent" BorderThickness="0" Padding="8,4"
                  Margin="6,0,0,0" CornerRadius="7" ToolTip.Tip="Dismiss">
            <TextBlock Text="✕" FontSize="11" Foreground="#9A9DA3"/>
          </Button>
        </Grid>
      </Border>

      <!-- 2×2 grid of stat panels -->
      <Grid RowDefinitions="*,*" ColumnDefinitions="*,*" Margin="8">

        <!-- Tag carries hex accent color string; CircularGauge parses it via converter.
             Palette validated for the dark surface (OKLCH band, ≥3:1 contrast, CVD-safe
             for all grid-adjacent pairs; re-validated vs #17181A 2026-07-05):
             blue / magenta / aqua / yellow. -->
        <views:StatPanelView Name="CpuPanel" Grid.Row="0" Grid.Column="0"
                             DataContext="{CompiledBinding Cpu}"
                             Tag="3987E5"/>

        <views:StatPanelView Name="GpuPanel" Grid.Row="0" Grid.Column="1"
                             DataContext="{CompiledBinding Gpu}"
                             Tag="D55181"/>

        <views:StatPanelView Name="MemPanel" Grid.Row="1" Grid.Column="0"
                             DataContext="{CompiledBinding Memory}"
                             Tag="199E70"/>

        <views:StatPanelView Name="StoPanel" Grid.Row="1" Grid.Column="1"
                             DataContext="{CompiledBinding Storage}"
                             Tag="C98500"/>

      </Grid>
    </DockPanel>

    <!-- First-close prompt overlay. ZIndex above the settings page so closing
         from either the dashboard OR the settings view shows the prompt. -->
    <Border Name="ClosePromptOverlay"
            IsVisible="False"
            ZIndex="10"
            Background="#CC0B0B0C">
      <Border Background="#17181A"
              BorderBrush="#2A2B2F"
              BorderThickness="1"
              CornerRadius="14"
              Padding="28,24"
              MaxWidth="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="14">
          <TextBlock Text="Keep monitoring in the background?"
                     FontSize="15" FontWeight="SemiBold" Foreground="#ECEDEF"/>
          <TextBlock Text="Choose what the close button should do. You can change this anytime from the ⚙ settings."
                     FontSize="12" Foreground="#9A9DA3" TextWrapping="Wrap"/>
          <CheckBox Name="RememberChoiceCheck" IsChecked="True"
                    Foreground="#9A9DA3" FontSize="12"
                    Content="Remember my choice"/>
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Name="PromptTrayButton" Click="OnPromptTrayClick"
                    Background="#2A5A9E" Foreground="#ECEDEF" Padding="14,8" CornerRadius="8">
              <TextBlock Text="Minimize to tray" FontSize="12"/>
            </Button>
            <Button Name="PromptExitButton" Click="OnPromptExitClick"
                    Background="#242528" Foreground="#ECEDEF" Padding="14,8" CornerRadius="8">
              <TextBlock Text="Close app" FontSize="12"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    <!-- Settings page — full-window takeover, sectioned cards, live preview -->
    <Border Name="SettingsOverlay"
            IsVisible="False"
            Background="#0F0F10">
      <DockPanel>

        <!-- Settings header -->
        <Border DockPanel.Dock="Top" Height="50"
                BorderBrush="#1F2023" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="16,0,22,0">
            <Button Grid.Column="0" Name="SettingsDoneButton" Click="OnSettingsDoneClick"
                    Background="Transparent" BorderThickness="0" Padding="10,6"
                    CornerRadius="8" VerticalAlignment="Center">
              <Button.Styles>
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                  <Setter Property="Background" Value="#1C1D20"/>
                </Style>
              </Button.Styles>
              <TextBlock Text="←" FontSize="17" Foreground="#ECEDEF"/>
            </Button>
            <TextBlock Grid.Column="1" Text="Settings" FontSize="15" FontWeight="SemiBold"
                       Foreground="#ECEDEF" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,14,0">
              <TextBlock Name="SettingsVersionText" Text="v1.0.0"
                         FontSize="11" Foreground="#6E7176" VerticalAlignment="Center"/>
              <Button Name="SettingsUpdateButton" Click="OnCheckUpdatesClick"
                      Background="#242528" Foreground="#DFE0E3" Padding="10,3"
                      CornerRadius="6" FontSize="11" Content="Check for updates"/>
            </StackPanel>
            <TextBlock Grid.Column="3" Text="changes apply instantly"
                       FontSize="10" Foreground="#6E7176" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Sidebar-tab layout: nav rail + one roomy section at a time -->
        <Grid ColumnDefinitions="168,*">
          <Grid.Styles>
            <!-- Sidebar nav item: icon + label, filled block when active (Sample B) -->
            <Style Selector="RadioButton.nav">
              <Setter Property="Template">
                <ControlTemplate>
                  <Border Name="root" CornerRadius="8" Background="Transparent" Padding="12,9">
                    <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Setter>
              <Setter Property="Margin" Value="0,2"/>
            </Style>
            <Style Selector="RadioButton.nav TextBlock">
              <Setter Property="Foreground" Value="#9A9DA3"/>
              <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style Selector="RadioButton.nav Path">
              <Setter Property="Stroke" Value="#9A9DA3"/>
            </Style>
            <Style Selector="RadioButton.nav:pointerover /template/ Border#root">
              <Setter Property="Background" Value="#1B1C1F"/>
            </Style>
            <Style Selector="RadioButton.nav:pointerover TextBlock">
              <Setter Property="Foreground" Value="#DFE0E3"/>
            </Style>
            <Style Selector="RadioButton.nav:pointerover Path">
              <Setter Property="Stroke" Value="#DFE0E3"/>
            </Style>
            <Style Selector="RadioButton.nav:checked /template/ Border#root">
              <Setter Property="Background" Value="#1C2634"/>
            </Style>
            <Style Selector="RadioButton.nav:checked TextBlock">
              <Setter Property="Foreground" Value="#ECEDEF"/>
            </Style>
            <Style Selector="RadioButton.nav:checked Path">
              <Setter Property="Stroke" Value="#3987E5"/>
            </Style>
          </Grid.Styles>

          <!-- Nav rail: icon + label -->
          <Border Grid.Column="0" Background="#141517"
                  BorderBrush="#1F2023" BorderThickness="0,0,1,0">
            <StackPanel Margin="12,16" Spacing="2">
              <RadioButton Classes="nav" Name="NavGeneral" GroupName="SettingsNav" IsChecked="True">
                <StackPanel Orientation="Horizontal" Spacing="11">
                  <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.4"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M5.2 8 A2.8 2.8 0 0 1 10.8 8 A2.8 2.8 0 0 1 5.2 8 M8 1.5 V3.2 M8 12.8 V14.5 M1.5 8 H3.2 M12.8 8 H14.5 M3.6 3.6 L4.8 4.8 M11.2 11.2 L12.4 12.4 M12.4 3.6 L11.2 4.8 M4.8 11.2 L3.6 12.4"/>
                  <TextBlock Text="General" VerticalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <RadioButton Classes="nav" Name="NavOverlay" GroupName="SettingsNav">
                <StackPanel Orientation="Horizontal" Spacing="11">
                  <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.4"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M2 4 H14 V11.5 H2 Z M8.6 5.7 H12.3 V7.3 H8.6 Z"/>
                  <TextBlock Text="Overlay" VerticalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
              <RadioButton Classes="nav" Name="NavAppearance" GroupName="SettingsNav">
                <StackPanel Orientation="Horizontal" Spacing="11">
                  <Path Width="16" Height="16" Stretch="Uniform" StrokeThickness="1.4"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="M4 2.5 V13.5 M12 2.5 V13.5 M2.3 5.5 H5.7 M10.3 10 H13.7"/>
                  <TextBlock Text="Appearance" VerticalAlignment="Center"/>
                </StackPanel>
              </RadioButton>
            </StackPanel>
          </Border>

          <!-- Content pane — one page visible at a time -->
          <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled" Padding="26,20">
            <Panel>

              <!-- GENERAL -->
              <StackPanel Name="PageGeneral" Spacing="22">
                <StackPanel Spacing="11">
                  <TextBlock Text="WHEN I CLOSE THE WINDOW" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <StackPanel Spacing="10">
                    <RadioButton Name="SettingTrayRadio" GroupName="CloseBehavior"
                                 Foreground="#DFE0E3" FontSize="13" Content="Minimize to tray"/>
                    <RadioButton Name="SettingExitRadio" GroupName="CloseBehavior"
                                 Foreground="#DFE0E3" FontSize="13" Content="Close completely"/>
                    <RadioButton Name="SettingAskRadio" GroupName="CloseBehavior"
                                 Foreground="#DFE0E3" FontSize="13" Content="Ask every time"/>
                  </StackPanel>
                </StackPanel>
                <StackPanel Spacing="11">
                  <TextBlock Text="STARTUP" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Start with Windows" FontSize="13" Foreground="#DFE0E3"/>
                      <TextBlock Text="Launch automatically at logon — no UAC prompt"
                                 FontSize="11" Foreground="#6E7176" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" Name="SettingStartup"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="11">
                  <TextBlock Text="PERFORMANCE" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Potato mode" FontSize="13" Foreground="#DFE0E3"/>
                      <TextBlock Text="Drop animations &amp; effects to save CPU/RAM"
                                 FontSize="11" Foreground="#6E7176" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" Name="SettingPotato"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Monotone theme" FontSize="13"
                               Foreground="#DFE0E3" VerticalAlignment="Center"
                               ToolTip.Tip="Single-tone theme — no accent colors"/>
                    <ToggleSwitch Grid.Column="1" Name="SettingMonotone"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                </StackPanel>
              </StackPanel>

              <!-- OVERLAY -->
              <StackPanel Name="PageOverlay" Spacing="22" IsVisible="False">
                <StackPanel Spacing="11">
                  <TextBlock Text="DESKTOP OVERLAY" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                      <TextBlock Text="Show overlay" FontSize="13" Foreground="#DFE0E3"
                                 VerticalAlignment="Center"/>
                      <Border Background="#1F2023" CornerRadius="4" Padding="5,1" VerticalAlignment="Center"
                              ToolTip.Tip="Global shortcut — toggles the overlay even while a game is focused">
                        <TextBlock Text="Alt+M" FontSize="9" FontWeight="SemiBold"
                                   LetterSpacing="0.5" Foreground="#9A9DA3"/>
                      </Border>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" Name="SettingOverlayCheck"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Show temperatures" FontSize="13"
                               Foreground="#DFE0E3" VerticalAlignment="Center"/>
                    <ToggleSwitch Grid.Column="1" Name="SettingShowTemps"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Icons instead of text" FontSize="13"
                               Foreground="#DFE0E3" VerticalAlignment="Center"/>
                    <ToggleSwitch Grid.Column="1" Name="SettingOverlayIcons"
                                  OnContent="" OffContent="" VerticalAlignment="Center" Margin="0,-6"/>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="11">
                  <TextBlock Text="METRICS SHOWN" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Name="SettingShowFps" Content="FPS" Foreground="#DFE0E3" FontSize="12.5"
                              ToolTip.Tip="Frame rate of the foreground game (uses a bit of CPU while enabled)"/>
                    <CheckBox Name="SettingShowCpu" Content="CPU" Foreground="#DFE0E3" FontSize="12.5"/>
                    <CheckBox Name="SettingShowGpu" Content="GPU" Foreground="#DFE0E3" FontSize="12.5"/>
                    <CheckBox Name="SettingShowRam" Content="RAM" Foreground="#DFE0E3" FontSize="12.5"/>
                    <CheckBox Name="SettingShowDisk" Content="Disk" Foreground="#DFE0E3" FontSize="12.5"/>
                  </StackPanel>
                </StackPanel>
                <StackPanel Spacing="11">
                  <TextBlock Text="DISPLAY" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid Name="OverlayMonitorRow" ColumnDefinitions="Auto,*" IsVisible="False">
                    <TextBlock Grid.Column="0" Text="Monitor" FontSize="13" Foreground="#DFE0E3"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               ToolTip.Tip="Which display the overlay docks to"/>
                    <ComboBox Grid.Column="1" Name="SettingOverlayMonitor" FontSize="12"
                              HorizontalAlignment="Stretch"/>
                  </Grid>
                </StackPanel>
              </StackPanel>

              <!-- APPEARANCE -->
              <StackPanel Name="PageAppearance" Spacing="20" IsVisible="False">
                <StackPanel Spacing="11">
                  <TextBlock Text="LAYOUT" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="5">
                      <TextBlock Text="Position" FontSize="11" Foreground="#9A9DA3"/>
                      <ComboBox Name="SettingOverlayPos" FontSize="12" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Top right"/>
                        <ComboBoxItem Content="Top center"/>
                        <ComboBoxItem Content="Top left"/>
                        <ComboBoxItem Content="Bottom right"/>
                        <ComboBoxItem Content="Bottom center"/>
                        <ComboBoxItem Content="Bottom left"/>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="5">
                      <TextBlock Text="Size" FontSize="11" Foreground="#9A9DA3"/>
                      <ComboBox Name="SettingOverlaySize" FontSize="12" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Small"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="Large"/>
                      </ComboBox>
                    </StackPanel>
                  </Grid>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Top gap" FontSize="11" Foreground="#9A9DA3"
                                   ToolTip.Tip="Pixels from the top/bottom edge the overlay docks to"/>
                        <TextBlock Grid.Column="1" Name="SettingOffsetYValue" Text="16"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#ECEDEF"/>
                      </Grid>
                      <Slider Name="SettingOffsetY" Minimum="0" Maximum="600"
                              TickFrequency="2" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Side gap" FontSize="11" Foreground="#9A9DA3"
                                   ToolTip.Tip="Pixels from the left/right edge; not used for center positions"/>
                        <TextBlock Grid.Column="1" Name="SettingOffsetXValue" Text="16"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#ECEDEF"/>
                      </Grid>
                      <Slider Name="SettingOffsetX" Minimum="0" Maximum="600"
                              TickFrequency="2" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <StackPanel Spacing="11">
                  <TextBlock Text="STYLE" FontSize="10" FontWeight="SemiBold"
                             LetterSpacing="1.3" Foreground="#6E7176"/>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="5">
                      <TextBlock Text="Background" FontSize="11" Foreground="#9A9DA3"/>
                      <ComboBox Name="SettingOverlayBg" FontSize="12" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Black"/>
                        <ComboBoxItem Content="Slate"/>
                        <ComboBoxItem Content="Invisible"/>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="5">
                      <TextBlock Text="Shape" FontSize="11" Foreground="#9A9DA3"/>
                      <ComboBox Name="SettingCorner" FontSize="12" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Pill"/>
                        <ComboBoxItem Content="Rounded"/>
                        <ComboBoxItem Content="Rectangle"/>
                      </ComboBox>
                    </StackPanel>
                  </Grid>
                  <StackPanel Spacing="5">
                    <TextBlock Text="Font" FontSize="11" Foreground="#9A9DA3"/>
                    <ComboBox Name="SettingOverlayFont" FontSize="12" HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="Inter" FontFamily="Inter"/>
                      <ComboBoxItem Content="Segoe UI" FontFamily="Segoe UI"/>
                      <ComboBoxItem Content="Consolas" FontFamily="Consolas"/>
                      <ComboBoxItem Content="Bahnschrift" FontFamily="Bahnschrift"/>
                      <ComboBoxItem Content="Arial" FontFamily="Arial"/>
                      <ComboBoxItem Content="Cascadia Mono" FontFamily="Cascadia Mono, Consolas"/>
                      <ComboBoxItem Content="Verdana" FontFamily="Verdana"/>
                      <ComboBoxItem Content="Tahoma" FontFamily="Tahoma"/>
                    </ComboBox>
                  </StackPanel>
                  <Grid ColumnDefinitions="*,14,*">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Font size" FontSize="11" Foreground="#9A9DA3"/>
                        <TextBlock Grid.Column="1" Name="SettingFontSizeValue" Text="10.5"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#ECEDEF"/>
                      </Grid>
                      <Slider Name="SettingFontSize" Minimum="8" Maximum="20"
                              TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Opacity" FontSize="11" Foreground="#9A9DA3"/>
                        <TextBlock Grid.Column="1" Name="SettingOpacityValue" Text="90%"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#ECEDEF"/>
                      </Grid>
                      <Slider Name="SettingOpacity" Minimum="0" Maximum="100"
                              TickFrequency="5" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </StackPanel>

            </Panel>
          </ScrollViewer>
        </Grid>
      </DockPanel>
    </Border>

  </Panel>
</Window>
